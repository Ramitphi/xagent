# X credentials (OAuth 1.0a user context)
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Numeric user id of the bot account that posts replies
X_BOT_USER_ID=

# OpenAI settings used by the in-process OpenClaw X plugin
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20
REQUEST_TIMEOUT_SECONDS=20

# Onchain analysis skill endpoint (async submit + poll)
ONCHAIN_ANALYSIS_URL=https://esraarlhpxraucslsdle.supabase.co/functions/v1/onchain-analysis
ONCHAIN_POLL_INTERVAL_SECONDS=20
ONCHAIN_MAX_WAIT_SECONDS=420

# OpenClaw runtime
OPENCLAW_HOME=/app/.openclaw
OPENCLAW_STATE_DIR=/app/.openclaw/state
LOG_LEVEL=INFO
