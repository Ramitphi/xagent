# X credentials (OAuth 1.0a user context)
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Numeric user id of the bot account that posts replies
X_BOT_USER_ID=

# Optional OpenAI settings for LLM-first routing and drafting
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=20
LLM_CONFIDENCE_THRESHOLD=0.65
LLM_MAX_CONTEXT_CHARS=4000
GENERAL_REPLY_ENABLED=true
GENERAL_REPLY_COOLDOWN_SECONDS=600
GENERAL_REPLY_MAX_REGEN_ATTEMPTS=1
PERSONA_FILE=agent.md
SKIP_EXISTING_MENTIONS_ON_STARTUP=true
PROCESSED_MENTIONS_CACHE_SIZE=2000

# Onchain analysis skill endpoint (async submit + poll)
ONCHAIN_ANALYSIS_URL=https://esraarlhpxraucslsdle.supabase.co/functions/v1/onchain-analysis
ONCHAIN_POLL_INTERVAL_SECONDS=20
ONCHAIN_MAX_WAIT_SECONDS=420

# Agent behavior
POLL_INTERVAL_SECONDS=60
MAX_MENTIONS_PER_POLL=10
REQUEST_TIMEOUT_SECONDS=20
STATE_FILE=state.json
LOG_LEVEL=INFO
