# X credentials (OAuth 1.0a user context)
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Numeric user id of the bot account that posts replies
X_BOT_USER_ID=

# API endpoint that generates reply text from a mention payload
ANALYSIS_API_URL=

# Optional API auth
ANALYSIS_API_KEY=
ANALYSIS_API_KEY_HEADER=Authorization

# Agent behavior
POLL_INTERVAL_SECONDS=60
MAX_MENTIONS_PER_POLL=10
REQUEST_TIMEOUT_SECONDS=20
STATE_FILE=state.json
LOG_LEVEL=INFO
